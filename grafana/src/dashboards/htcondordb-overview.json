{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["htcondor", "htcondordb"],
  "title": "HTCondorDB Overview",
  "uid": "htcondordb-overview",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "bbockelm-htcondordb-datasource",
        "refresh": 1,
        "hide": 0,
        "current": {}
      },
      {
        "name": "owner",
        "label": "Owner",
        "type": "query",
        "datasource": { "type": "bbockelm-htcondordb-datasource", "uid": "${datasource}" },
        "query": "SELECT DISTINCT Owner FROM jobs",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Jobs by owner",
      "type": "barchart",
      "datasource": { "type": "bbockelm-htcondordb-datasource", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "bbockelm-htcondordb-datasource", "uid": "${datasource}" },
          "editorMode": "builder",
          "table": "jobs",
          "groupBy": ["Owner"],
          "metrics": [{ "func": "COUNT", "attr": "*" }]
        }
      ]
    },
    {
      "id": 2,
      "title": "Machines by state",
      "type": "piechart",
      "datasource": { "type": "bbockelm-htcondordb-datasource", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "bbockelm-htcondordb-datasource", "uid": "${datasource}" },
          "editorMode": "builder",
          "table": "machines",
          "groupBy": ["State"],
          "metrics": [{ "func": "COUNT", "attr": "*" }]
        }
      ]
    },
    {
      "id": 3,
      "title": "Jobs for $owner",
      "type": "table",
      "datasource": { "type": "bbockelm-htcondordb-datasource", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "bbockelm-htcondordb-datasource", "uid": "${datasource}" },
          "editorMode": "code",
          "rawSql": "SELECT Key, Owner, JobStatus, RequestCpus FROM jobs WHERE Owner == \"$owner\" ORDER BY Key"
        }
      ]
    }
  ]
}
